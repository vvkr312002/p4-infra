{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/securechat/app-out.log",
            "log_group_name": "/securechat/app",
            "log_stream_name": "{instance_id}/app-stdout",
            "timezone": "UTC",
            "timestamp_format": "%Y-%m-%d %H:%M:%S",
            "multi_line_start_pattern": "^\\d{4}-\\d{2}-\\d{2}"
          },
          {
            "file_path": "/var/log/securechat/app-err.log",
            "log_group_name": "/securechat/app",
            "log_stream_name": "{instance_id}/app-stderr",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/nginx/securechat-access.log",
            "log_group_name": "/securechat/nginx",
            "log_stream_name": "{instance_id}/nginx-access",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/nginx/securechat-error.log",
            "log_group_name": "/securechat/nginx",
            "log_stream_name": "{instance_id}/nginx-error",
            "timezone": "UTC"
          },
          {
            "file_path": "/var/log/securechat-setup.log",
            "log_group_name": "/securechat/app",
            "log_stream_name": "{instance_id}/ec2-setup",
            "timezone": "UTC"
          }
        ]
      }
    },
    "log_stream_name": "{instance_id}/default",
    "force_flush_interval": 15
  },
  "metrics": {
    "namespace": "SecureChat/EC2",
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_idle", "cpu_usage_user", "cpu_usage_system"],
        "metrics_collection_interval": 60,
        "totalcpu": true
      },
      "mem": {
        "measurement": ["mem_used_percent"],
        "metrics_collection_interval": 60
      },
      "disk": {
        "measurement": ["disk_used_percent"],
        "metrics_collection_interval": 60,
        "resources": ["/"]
      },
      "net": {
        "measurement": ["net_bytes_sent", "net_bytes_recv"],
        "metrics_collection_interval": 60
      }
    }
  }
}
